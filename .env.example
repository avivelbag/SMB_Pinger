# SMB Pinger Configuration
# Copy to .env and fill in values

# Database path (default: data/smb_pinger.db)
# SMB_PINGER_DB_PATH=data/smb_pinger.db

# Pinger settings
# SMB_PINGER_CHECK_INTERVAL_MINUTES=15
# SMB_PINGER_CONCURRENCY_LIMIT=30
# SMB_PINGER_TIMEOUT_SECONDS=15
# SMB_PINGER_MAX_REDIRECTS=5

# Admin auth (REQUIRED - generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())")
SMB_PINGER_ADMIN_PASSWORD_HASH=

# Server
# SMB_PINGER_HOST=127.0.0.1
# SMB_PINGER_PORT=8000
